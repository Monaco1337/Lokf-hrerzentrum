// Prisma schema for Fairtrain Lead Funnel
//
// Provider: postgresql (Vercel / production). All enum-like columns are stored
// as String and validated via zod + TypeScript enums at every application
// boundary (Repository read, Service input, Action input).
// See src/features/fairtrain-funnel/types.ts for the source of truth of every enum.
//
// A later optional migration can convert these String columns to native
// Postgres enums.

generator client {
  provider      = "prisma-client-js"
  // native covers local dev (darwin/darwin-arm64); rhel-openssl-3.0.x is the
  // Vercel build & lambda runtime (Amazon Linux 2023 / OpenSSL 3). Keeping the
  // explicit darwin targets avoids regenerating when the local arch is misdetected.
  binaryTargets = ["native", "darwin", "darwin-arm64", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Core entity: Lead
// ----------------------------------------------------------------------------

model Lead {
  id String @id @default(cuid())

  // base data
  firstName String
  lastName  String
  email     String
  phone     String
  city      String?

  // funnel routing - enum-validated via zod (FunnelPath, EmploymentStatus, PreferredLocation)
  funnelPath        String
  employmentStatus  String
  preferredLocation String
  acceptsShiftWork  Boolean
  motivationText    String?

  // extended person data (added 2026-05-19)
  birthDate   DateTime?
  birthPlace  String?
  street      String?
  houseNumber String?
  postalCode  String?
  addressCity String?
  nationality String?

  // agency data (for arbeitslos/arbeitssuchend funnel)
  agencyCity           String?
  agencyCustomerNumber String?
  agencyCaseWorker     String?

  // CV / live-interview data (used to generate Lebenslauf later)
  unemployedSince String?
  careerHistory   String?
  schoolEducation String?
  graduationYear  String?
  languages       String?
  computerSkills  String?
  interests       String?

  // K.O. answers (denormalized for fast CRM filtering;
  // canonical record stays in EligibilityAnswer)
  acceptsTravelHotel  Boolean?
  acceptsPsychLoad    Boolean?
  hasNoKbaDrugEntries Boolean?

  // applicant self-service portal fields (added 2026-06-18)
  availability        String?
  agencyStatus        String? // funding/agency situation as stated in the portal
  hasEducationVoucher Boolean? // Bildungsgutschein vorhanden?
  hasDrivingLicense   Boolean?

  // scoring snapshot (truth lives in EligibilityAnswer/SensitiveAnswers/StatusHistory)
  score    Int
  priority String // LeadPriority enum
  status   String @default("NEW") // LeadStatus enum

  // WhatsApp status tracking (added 2026-07-09). Driven ONLY by real provider
  // webhook events — never simulated. `leadScore` is the WhatsApp/engagement
  // score and is intentionally separate from `score` (eligibility snapshot).
  whatsappStatus          String    @default("offen") // WhatsappTrackingStatus
  whatsappReachability     String   @default("unbekannt") // WhatsappReachability
  leadQualityStatus        String   @default("unbewertet") // LeadQualityStatus
  leadScore                Int       @default(0)
  lastWhatsappMessageAt    DateTime?
  lastWhatsappDeliveredAt  DateTime?
  lastWhatsappReadAt       DateTime?
  lastWhatsappReplyAt      DateTime?
  lastWhatsappErrorAt      DateTime?
  lastWhatsappErrorReason  String?
  lastInboundMessage       String?
  lastInboundMessageAt     DateTime?

  // WhatsApp opt-out (added 2026-07-13). Driven by real inbound stop keywords
  // (STOP/STOPP/ABMELDEN/…). When `optOut` is true the lead is NEVER contacted
  // via WhatsApp again (marketing + automation + campaigns all skip), but stays
  // fully in the CRM. `tags` is a free-form label set incl. `whatsapp_opt_out`.
  optOut               Boolean   @default(false)
  optOutAt             DateTime?
  whatsappMarketing    Boolean   @default(true)
  tags                 String[]  @default([])

  // Contact protection (added 2026-07-14). A lead being handled by a human
  // (call / Multichat) that now waits for the applicant to act must NOT receive
  // any further automatic reactivation / follow-up / WhatsApp / e-mail.
  // `contactState` is a SEPARATE German handling lifecycle; it never touches
  // `status` (pipeline) or `campaignStatus`. `reactivationExcluded` hard-blocks
  // the lead from any future campaign, independent of contactState.
  contactState             String    @default("none") // ContactState enum
  reactivationExcluded     Boolean   @default(false)
  lastManualContactAt      DateTime?
  lastManualContactBy      String? // user id who last handled the lead manually
  lastManualContactChannel String? // "whatsapp" | "phone" | "multichat" | …

  // Funnel-Phase (added 2026-07-14). The PROCESS step, fully separate from
  // `status` (communication status). Enum-validated via funnelPhase.ts. Default
  // "none" keeps every existing lead/automation behaving exactly as before.
  funnelPhase String @default("none") // FunnelPhase enum

  // AI reply analysis (added 2026-07-14). Deterministic classification of the
  // last inbound WhatsApp reply. The KI ONLY classifies — it never generates
  // messages. `needsManualReview` is set when confidence is too low so no wrong
  // automation is started.
  replyInterest     String? // "yes" | "no" | "unknown"
  replyIntent       String? // ReplyIntent (primary detected intent)
  replyConfidence   Int? // 0..100
  needsManualReview Boolean @default(false)

  // Reactivation campaign layer (added 2026-07-09). Additive to the pipeline
  // status/state-machine — `campaignStatus` is a SEPARATE German lifecycle for
  // the Alt-Lead reactivation flow and never touches `status`.
  leadType             String    @default("neu") // "neu" | "alt_lead"
  campaign             String? // e.g. "reaktivierung_alt_leads"
  campaignStatus       String? // CampaignStatus enum (German)
  campaignStep         Int       @default(0) // 0=none, 1=Tag0 sent, 2=Follow-up 1, 3=Follow-up 2
  communicationStarted Boolean   @default(false)
  firstContactSentAt   DateTime?
  automationPaused     Boolean   @default(false)
  campaignCompleted    Boolean   @default(false)
  employmentSnapshot   String? // snapshot at import, e.g. "arbeitslos_nein"
  nextCampaignActionAt DateTime? // drives the campaign runner (separate from nextFollowUpAt)

  // Alt-Lead callback requests (added 2026-07-15). Set when the AI detects a
  // callback/consultation request from a reactivated Alt-Lead in Multichat
  // (see CallbackRequestService). `callbackRequestedAt` marks WHEN the
  // request came in; `callbackHandledAt` is null while the request is still
  // open (queue = alt_lead + callbackRequestedAt set + callbackHandledAt
  // null) and set once an operator called back / picked a next step. Never
  // touches `leadType`/`status` directly by itself.
  callbackRequestedAt DateTime?
  callbackHandledAt   DateTime?

  // SLA
  slaBreachedAt  DateTime?
  nextFollowUpAt DateTime?

  // ownership — `assignedTo` (legacy free-text) is kept for backward
  // compatibility. The canonical reference is `assignedToId` → User.
  assignedTo     String?
  assignedToId   String?
  assignedToUser User?     @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt     DateTime?
  assignedById   String? // user id who performed the assignment (audit hint)

  // attribution
  source String?
  utm    String?

  // soft delete reserve (not used in MVP; DSGVO erasure is a future flow)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  sensitive           SensitiveAnswers?
  eligibilityAnswers  EligibilityAnswer[]
  statusHistory       StatusHistory[]
  notes               Note[]
  documents           Document[]
  uploadedFiles       UploadedFile[]
  communicationEvents CommunicationEvent[]
  magicLinkTokens     MagicLinkToken[]
  consentRecords      ConsentRecord[]
  automationLogs      AutomationLog[]
  callLogs            CallLog[]
  tasks               Task[]
  portalLinks         PortalLink[]
  portalDocuments     PortalDocument[]
  campaignJobs        CampaignMessageJob[]
  workflowRuns        WorkflowRun[]

  @@index([status])
  @@index([priority])
  @@index([preferredLocation])
  @@index([createdAt])
  @@index([slaBreachedAt])
  @@index([assignedToId])
  @@index([whatsappStatus])
  @@index([leadQualityStatus])
  @@index([optOut])
  @@index([contactState])
  @@index([reactivationExcluded])
  @@index([funnelPhase])
  @@index([needsManualReview])
  @@index([leadType])
  @@index([campaign])
  @@index([campaignStatus])
  @@index([nextCampaignActionAt])
  @@index([callbackRequestedAt])
  @@index([callbackHandledAt])
}

// ----------------------------------------------------------------------------
// User-uploaded files (CV, Zeugnis, etc.). Distinct from generated Documents.
// Files are stored via StorageAdapter (local disk in dev, S3-compatible in prod).
// Soft-delete via deletedAt for DSGVO erasure workflow.
// ----------------------------------------------------------------------------

model UploadedFile {
  id String @id @default(cuid())

  // Files are uploaded BEFORE the Lead exists. During the draft phase `leadId`
  // is null and `draftId` carries the wizard's random draft identifier. On
  // submit, LeadService.attachFilesToLead rewrites `leadId` to the real id.
  // A janitor can purge orphan rows that still have draftId but no leadId.
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  draftId String?

  kind         String // UploadedFileKind enum: CV | CERTIFICATE | ID | OTHER
  originalName String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  sha256       String

  // Actual bytes, stored in Postgres so uploads survive on ephemeral/serverless
  // hosts (Vercel) where the local filesystem is not persistent. The filesystem
  // adapter remains a best-effort mirror for local dev. NEVER select this column
  // in list queries — only when streaming a single file.
  data Bytes?

  uploadedAt DateTime  @default(now())
  deletedAt  DateTime?

  @@index([leadId])
  @@index([leadId, deletedAt])
  @@index([draftId])
}

// ----------------------------------------------------------------------------
// Sensitive: MPU/Drogen-Angaben - logisch getrennt, niemals in Listen.
// 1:1 to Lead.
// ----------------------------------------------------------------------------

model SensitiveAnswers {
  id String @id @default(cuid())

  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  hasMpuIssue    Boolean
  hasDrugIssue   Boolean
  notesSensitive String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Eligibility answers: configurable question/answer pairs keyed by questionId
// from the in-repo configuration (eligibilityQuestions.ts).
// ----------------------------------------------------------------------------

model EligibilityAnswer {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  questionId String
  answer     String
  score      Int    @default(0)

  createdAt DateTime @default(now())

  @@index([leadId])
}

// ----------------------------------------------------------------------------
// Append-only: StatusHistory
// Repositories MUST NOT expose update/delete on this table.
// ----------------------------------------------------------------------------

model StatusHistory {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  fromStatus String? // LeadStatus enum (nullable for initial NEW)
  toStatus   String // LeadStatus enum
  changedBy  String
  reason     String?

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

// ----------------------------------------------------------------------------
// Notes (mutable, but editedAt is tracked)
// ----------------------------------------------------------------------------

model Note {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  body   String
  author String

  createdAt DateTime  @default(now())
  editedAt  DateTime?

  @@index([leadId, createdAt])
}

// ----------------------------------------------------------------------------
// Documents - storageKey is cloud-storage-friendly (S3/MinIO/local).
// ----------------------------------------------------------------------------

model Document {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type   String // DocumentType enum
  status String @default("MISSING_DATA") // DocumentStatus enum

  storageKey  String?
  generatedAt DateTime?
  sentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadId, type])
  @@index([leadId])
}

// ----------------------------------------------------------------------------
// Append-only: CommunicationEvent
// ----------------------------------------------------------------------------

model CommunicationEvent {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel           String // CommunicationChannel enum: WHATSAPP | EMAIL | SMS | INTERNAL
  direction         String // CommunicationDirection enum: OUT | IN
  payload           String // message body
  providerMessageId String?
  errorCode         String?

  // Message ledger fields (added 2026-06-18). The CommunicationEvent IS the
  // message ledger — a future real WhatsApp Cloud API adapter only swaps the
  // service that writes these rows, not the schema or UI.
  type              String  @default("TEXT") // MessageType: TEMPLATE | TEXT | SYSTEM | MEDIA
  templateId        String?
  templateName      String?
  variablesResolved String? // JSON object of resolved template variables
  status            String  @default("SENT") // MessageStatus: DRAFT|QUEUED|SENT|DELIVERED|READ|FAILED
  statusHistory     String  @default("[]") // JSON array of { status, at }
  sentBy            String  @default("SYSTEM") // MessageSentBy: AUTOMATION | ADMIN | SYSTEM
  actorId           String?
  isDemo            Boolean @default(true) // simulated until a real provider is wired
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  failedReason      String?

  // Which of OUR WhatsApp business numbers handled this message (Meta
  // `phone_number_id`). Null for legacy rows / non-WhatsApp channels. Drives the
  // multi-number Multichat inbox and reply-from-the-same-number routing.
  businessPhoneNumberId String?

  // WhatsApp status tracking (added 2026-07-09).
  repliedAt         DateTime? // set on the outbound msg when the lead replies
  rawWebhookPayload String? // last provider event JSON for this message (debug)

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([channel, direction])
  @@index([status])
  @@index([businessPhoneNumberId])
}

// ----------------------------------------------------------------------------
// WhatsappMessageEvent — append-only ledger of RAW provider webhook events.
//
// Two jobs: (1) idempotency — the unique (providerMessageId, eventType) key
// makes re-delivered webhooks a no-op; (2) debugging — the full raw payload is
// kept here (never on the lead). Not a message store; the message itself is
// `CommunicationEvent`.
// ----------------------------------------------------------------------------

model WhatsappMessageEvent {
  id String @id @default(cuid())

  // The CommunicationEvent this maps to (if we could correlate it).
  messageId String?
  leadId    String?

  provider          String // e.g. "meta"
  eventType         String // sent | delivered | read | failed | inbound | undeliverable
  providerMessageId String
  payload           String // raw provider event JSON

  createdAt DateTime @default(now())

  @@unique([providerMessageId, eventType])
  @@index([leadId, createdAt])
  @@index([messageId])
}

// ----------------------------------------------------------------------------
// Magic links - only the hash is stored.
// usedAt is the one mutable field; everything else is immutable after insert.
// ----------------------------------------------------------------------------

model MagicLinkToken {
  id String @id @default(cuid())

  tokenHash String @unique

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  scope     String // MagicLinkScope enum
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([leadId])
}

// ----------------------------------------------------------------------------
// PortalLink — long-lived, multi-open applicant self-service token.
//
// Distinct from MagicLinkToken (single-use). The URL carries only an opaque
// plaintext token; the DB stores `sha256(token + pepper)`. The lead id is never
// part of the URL, so the portal is not guessable from a lead id.
// ----------------------------------------------------------------------------

model PortalLink {
  id String @id @default(cuid())

  tokenHash String @unique

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status String @default("ACTIVE") // PortalLinkStatus: ACTIVE | OPENED | COMPLETED | DISABLED

  expiresAt   DateTime
  openedAt    DateTime?
  submittedAt DateTime?
  completedAt DateTime?

  /// Snapshot of the structured answers the applicant submitted (JSON).
  formData String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([status])
}

// ----------------------------------------------------------------------------
// PortalDocument — per-lead document checklist with review workflow.
// Status lifecycle: MISSING → REQUESTED → UPLOADED → APPROVED | REJECTED.
// In demo mode uploads carry placeholder metadata (no binary required).
// ----------------------------------------------------------------------------

model PortalDocument {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  kind   String // PortalDocumentKind
  status String @default("MISSING") // PortalDocumentStatus

  fileName       String? // uploaded/placeholder file name
  uploadedFileId String? // optional FK to a real UploadedFile (future storage)
  reviewerNote   String?
  reviewerId     String?

  requestedAt DateTime?
  uploadedAt  DateTime?
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadId, kind])
  @@index([leadId])
  @@index([status])
}

// ----------------------------------------------------------------------------
// Append-only: ConsentRecord
// A revoke creates a new record with action=REVOKE.
// The prior GRANT record is never modified (DSGVO audit trail).
// ----------------------------------------------------------------------------

model ConsentRecord {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type   String // ConsentType enum
  action String // ConsentAction enum

  source    String?
  utm       String?
  ipHash    String?
  userAgent String?

  // Opt-in proof: which version of the consent text the lead accepted. Lets us
  // prove the exact wording shown at capture time (WhatsApp Cloud API requires
  // demonstrable opt-in). Null for legacy records.
  textVersion String?

  createdAt DateTime @default(now())

  @@index([leadId, type, createdAt])
}

// ----------------------------------------------------------------------------
// ContactInquiry - lightweight inbox for the public "Noch eine Frage?" form
// on the landing page. NOT a full Lead — kept intentionally separate so that
// the funnel scoring pipeline isn't polluted with cold inbound questions.
// The CRM lists these under /crm/inquiries.
// ----------------------------------------------------------------------------

model ContactInquiry {
  id String @id @default(cuid())

  firstName String
  lastName  String
  email     String
  phone     String?

  message String

  status String @default("NEW") // NEW | IN_PROGRESS | DONE | SPAM

  source    String?
  utm       String?
  ipHash    String?
  userAgent String?

  handledBy String?
  handledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Automation templates - editable in CRM admin. One row per trigger+channel.
// Body supports {{variable}} placeholders rendered server-side at send time.
// ----------------------------------------------------------------------------

model AutomationTemplate {
  id String @id @default(cuid())

  slug String @unique // e.g. "lead.created.email"

  trigger String // AutomationTrigger enum: LEAD_CREATED | MANUAL | …
  channel String // CommunicationChannel enum: EMAIL | WHATSAPP | INTERNAL

  name    String
  subject String? // email only
  body    String

  enabled         Boolean @default(true)
  requiresConsent String? // ConsentType enum — skip send when not granted

  // --- Configurable template system (admin-managed message blocks) ----------
  category          String  @default("welcome") // welcome | documents | reminder | …
  status            String  @default("active") // draft | active | inactive
  language          String  @default("de")
  metaTemplateName  String? // future WhatsApp Business template name
  metaApprovalStatus String? // not_submitted | pending | approved | rejected
  /// WhatsApp only: the chosen sender number (Meta `phone_number_id`) this
  /// template is sent FROM. Required for WhatsApp sends — never auto-picked.
  senderPhoneNumberId String?
  /// WhatsApp only: JSON array of ordered body parameters mapping our named
  /// variables onto Meta's numbered placeholders ({{1}}, {{2}}, …). Each entry
  /// is a template token (e.g. "{{first_name}}") or literal text, rendered in
  /// order at send time. Empty array = static template (no variables).
  metaBodyParams    String?
  /// WhatsApp only: JSON array of interactive Meta template buttons
  /// (Quick Reply / URL / Call) in approved order. Rendered into
  /// `template.components` at send time. Empty/null = no buttons.
  metaButtons       String?
  usageCount        Int      @default(0)
  lastUsedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs AutomationLog[]

  @@index([trigger, channel])
  @@index([enabled])
  @@index([category, status])
}

// ----------------------------------------------------------------------------
// AutomationRule — admin-configurable trigger → conditions → actions.
// `conditions` and `actions` are JSON strings (validated via zod at the
// boundary). Rules are SIMULATED only — no external messages are ever sent.
// ----------------------------------------------------------------------------

model AutomationRule {
  id String @id @default(cuid())

  name        String
  description String?

  trigger    String // AutomationTrigger enum
  conditions String @default("[]") // JSON array of {type, value?}
  // How the conditions are combined: "all" = UND (default), "any" = ODER.
  conditionLogic String @default("all")
  actions        String @default("[]") // JSON array of {type, …params}

  status  String @default("draft") // draft | active | inactive
  runMode String @default("demo") // demo | simulation | production_ready

  lastRunAt  DateTime?
  runCount   Int       @default(0)
  errorCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs AutomationRunLog[]

  @@index([trigger, status])
  @@index([status])
}

// ----------------------------------------------------------------------------
// AutomationRunLog — append-only history of (simulated) rule executions.
// `detail` holds a JSON snapshot of the actions the rule performed/simulated.
// ----------------------------------------------------------------------------

model AutomationRunLog {
  id String @id @default(cuid())

  ruleId String
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  leadId String? // optional lead the run acted on

  status  String // SIMULATED | SKIPPED | ERROR
  summary String // human-readable description of what happened
  detail  String @default("{}") // JSON: { actions: [...], conditions: [...] }

  isTest      Boolean @default(true)
  triggeredBy String  @default("system")

  createdAt DateTime @default(now())

  @@index([ruleId, createdAt])
  @@index([leadId])
}

// ----------------------------------------------------------------------------
// Append-only: AutomationLog — every automation attempt is persisted.
// Status values: SENT | FAILED | SKIPPED | SKIPPED_MISSING_PROVIDER_CONFIG
//                | SKIPPED_NO_CONSENT
// ----------------------------------------------------------------------------

model AutomationLog {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  templateId String?
  template   AutomationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  trigger String // AutomationTrigger enum
  channel String // CommunicationChannel enum
  status  String // AutomationLogStatus enum

  renderedSubject String?
  renderedBody    String

  providerMessageId String?
  errorCode         String?
  errorMessage      String?

  isTest      Boolean @default(false)
  triggeredBy String  @default("system")

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([status, createdAt])
  @@index([trigger, createdAt])
}

// ----------------------------------------------------------------------------
// Append-only: AuditLog
// Every access to sensitive data, every admin override, every login attempt.
// `actor` carries the User.id when available; "system" or a legacy string
// otherwise (kept compatible with pre-RBAC entries).
// ----------------------------------------------------------------------------

model AuditLog {
  id String @id @default(cuid())

  actor      String
  action     String // AuditAction enum
  entityType String
  entityId   String
  details    String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@index([actor, createdAt])
}

// ----------------------------------------------------------------------------
// DemoSeedEntry — registry of every entity created by the demo seeder.
// One row per entity. On "Demo-Daten entfernen" the service deletes every
// referenced row in dependency order. Production-safe because real data is
// never registered here.
// ----------------------------------------------------------------------------

model DemoSeedEntry {
  id String @id @default(cuid())

  entityType String // e.g. "Lead", "User", "Note", "CallLog", "AuditLog"
  entityId   String

  /// The seed batch identifier — useful when re-running the seeder.
  batch String @default("default")

  createdAt DateTime @default(now())

  @@unique([entityType, entityId])
  @@index([batch])
  @@index([entityType])
}

// ----------------------------------------------------------------------------
// User — operators of the CRM with role-based access control.
//
// Roles: SUPER_ADMIN | ADMIN | PARTNER_MANAGER | PARTNER_AGENT | READ_ONLY.
// `passwordHash` may be null for users created before they have set a
// password (bootstrap path). Email is the login identifier.
// ----------------------------------------------------------------------------

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String?

  role     String  @default("PARTNER_AGENT") // Role enum
  isActive Boolean @default(true)

  /// Optional avatar URL; renders as initials when null.
  avatar String?

  lastLoginAt       DateTime?
  mustChangePassword Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // relations
  assignedLeads  Lead[]    @relation("LeadAssignedTo")
  callLogs       CallLog[]
  tasksAssigned  Task[]    @relation("TaskAssignee")
  tasksCreated   Task[]    @relation("TaskCreatedBy")
  whatsappNumbers WhatsAppNumber[] @relation("WhatsAppNumberOwner")

  @@index([role])
  @@index([isActive])
}

// ----------------------------------------------------------------------------
// WhatsAppNumber — one row per WhatsApp Business Cloud API sender number.
//
// All numbers live under ONE WhatsApp Business Account (WABA); a single
// System-User token (env `META_WABA_TOKEN`) can send from every number, so we
// only persist the per-number `phoneNumberId` here (never a secret). Adding a
// new sales number = inserting a row via the admin UI, no deploy required.
//
// `assignedUser` is the Vertriebler who owns the number: inbound messages that
// arrive on this number are auto-assigned to them, and replies to that
// conversation go back out from this number.
// ----------------------------------------------------------------------------

model WhatsAppNumber {
  id String @id @default(cuid())

  /// Meta Cloud API `phone_number_id` (opaque id, NOT the phone number).
  phoneNumberId String @unique

  /// Human-readable E.164 number for display, e.g. "+4915112345678".
  displayPhone String

  /// Free-text label shown in the UI, e.g. "Vertrieb Danijel".
  label String

  /// Owning sales rep (auto-assignment target). Null = shared/unassigned.
  assignedUserId String?
  assignedUser   User?   @relation("WhatsAppNumberOwner", fields: [assignedUserId], references: [id], onDelete: SetNull)

  /// Deactivate a number without deleting its history/routing.
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([assignedUserId])
}

// ----------------------------------------------------------------------------
// CallLog — append-only documentation of every call attempt or conversation.
// Drives the Vertriebs-Tracking. One row per call. Notes mutate via append
// (each correction is a new row), so the audit trail stays intact.
// ----------------------------------------------------------------------------

model CallLog {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  outcome String // CallOutcome enum: ATTEMPT_NO_ANSWER | TALKED | INTERESTED | NOT_INTERESTED | NOT_ELIGIBLE | CALLBACK_SCHEDULED | APPOINTMENT_SET | CLOSED

  note     String?
  nextStep String?

  /// Optional scheduled callback / appointment derived from this call.
  callbackAt DateTime?

  /// Optional duration in seconds (for analytics later).
  durationSeconds Int?

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([userId, createdAt])
}

// ----------------------------------------------------------------------------
// Task — operational to-do that the team has to work off, optionally pinned
// to a specific Bewerber (Lead). Drives the "Aufgaben" kanban and feeds the
// Leitstand's "Heutige Prioritäten" with non-call work items.
//
// Status values (TaskStatus enum):
//   OPEN | PLANNED | IN_PROGRESS | WAIT_APPLICANT | WAIT_AGENCY | DONE
// Priority values (TaskPriority): LOW | NORMAL | HIGH | URGENT
// ----------------------------------------------------------------------------

model Task {
  id String @id @default(cuid())

  title       String
  description String?

  status   String @default("OPEN")
  priority String @default("NORMAL")

  /// Optional pin to a Bewerber. NULL = standalone task.
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  /// Optional owner. NULL = unassigned, anyone may pick it up.
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  /// Person who created the task (immutable, used for audit display).
  createdById String
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  dueAt       DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueAt])
  @@index([leadId])
  @@index([assigneeId, status])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// LeadImportBatch — one row per Excel/CSV Alt-Lead import (added 2026-07-09).
// Holds the aggregate counters for the campaign overview and enables a
// controlled release + rollback of an imported cohort.
// ----------------------------------------------------------------------------

model LeadImportBatch {
  id String @id @default(cuid())

  filename String
  leadType String @default("alt_lead")
  campaign String @default("reaktivierung_alt_leads")

  status String @default("imported") // imported | released | completed

  // aggregate counters (computed at import time)
  totalRows        Int @default(0)
  imported         Int @default(0)
  duplicates       Int @default(0)
  invalid          Int @default(0)
  alreadyContacted Int @default(0)
  whatsappAvailable Int @default(0)
  emailAvailable    Int @default(0)

  releaseTier   String? // "10" | "50" | "100" | "all" | "test5"
  releasedCount Int?
  releasedAt    DateTime?
  releasedById  String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rows LeadImportRow[]

  @@index([campaign, createdAt])
  @@index([status])
}

// ----------------------------------------------------------------------------
// LeadImportRow — per-row result of an import (idempotency + error/duplicate
// display). `rawJson` keeps the original row for auditing/rollback.
// ----------------------------------------------------------------------------

model LeadImportRow {
  id String @id @default(cuid())

  batchId String
  batch   LeadImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  rowIndex Int
  rawJson  String

  status      String // imported | duplicate | invalid | skipped
  leadId      String?
  errorReason String?

  phoneNormalized String?
  emailNormalized String?

  createdAt DateTime @default(now())

  @@index([batchId, status])
  @@index([phoneNormalized])
  @@index([emailNormalized])
}

// ----------------------------------------------------------------------------
// CampaignMessageJob — the reactivation send queue (added 2026-07-09).
// One row per (lead, step, channel). The unique constraint guarantees a lead
// is never contacted twice for the same step/channel (idempotency). The cron
// runner and the manual "Fällige senden" button both drain this table.
// ----------------------------------------------------------------------------

model CampaignMessageJob {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  campaign String
  step     Int // 1=Tag0 Erstkontakt, 2=Follow-up 1 (Tag 3), 3=Follow-up 2 (Tag 7)
  channel  String // WHATSAPP | EMAIL

  scheduledFor DateTime
  status       String   @default("queued") // queued | sent | skipped | failed | canceled

  sentAt            DateTime?
  providerMessageId String?
  reason            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leadId, step, channel])
  @@index([status, scheduledFor])
  @@index([campaign, step])
}

// ----------------------------------------------------------------------------
// Unified Workflow Engine (added 2026-07-15).
//
// ONE visual, branching process per business goal. A WorkflowDefinition holds
// the graph (nodes + edges) authored in the visual builder. A WorkflowRun is
// the per-lead execution state (a cursor into a graph snapshot) — it advances
// step by step, pauses on `wait`/`aiRouter`, resumes via cron or inbound, and
// guarantees a lead ever only gets the ONE next step. WorkflowRunStep is the
// append-only per-node ledger whose unique `dedupKey` makes every send/action
// idempotent (a node fires at most once per run → never a double message).
//
// Additive only. The legacy AutomationRule / CampaignMessageJob tables stay
// untouched so nothing is lost and rollback is instant.
// ----------------------------------------------------------------------------

model WorkflowDefinition {
  id String @id @default(cuid())

  name        String
  description String?

  // Which business process this workflow drives. Used for overview grouping and
  // for cross-process rules (e.g. funnel start cancels every `reactivation` run).
  processKey String // reactivation | application | inbound_router | custom
  trigger    String // WorkflowTrigger: MESSAGE_INBOUND | CAMPAIGN_ENROLL | LEAD_CREATED | FUNNEL_STARTED | FUNNEL_COMPLETED | MANUAL

  status  String @default("draft") // draft | active | inactive
  version Int    @default(1)

  // The visual graph: JSON { nodes: WorkflowNode[], edges: WorkflowEdge[] }.
  graph String @default("{\"nodes\":[],\"edges\":[]}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs WorkflowRun[]

  @@index([processKey, status])
  @@index([trigger, status])
}

model WorkflowRun {
  id String @id @default(cuid())

  definitionId      String
  definition        WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  definitionVersion Int                @default(1)
  processKey        String

  // Snapshot of the graph at enroll time so editing a definition never breaks
  // a lead mid-flight.
  graphSnapshot String @default("{}")

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status        String    @default("active") // active | waiting | completed | canceled | failed | manual_review
  currentNodeId String?
  resumeAt      DateTime? // when a `wait` node should resume
  enteredNodeAt DateTime  @default(now())
  lastInboundAt DateTime?

  // JSON: last classification, chosen path, reminder counters, etc.
  context String @default("{}")

  // Single-active-run guarantee: equals `processKey` while the run is
  // active/waiting, set to NULL when terminal. Postgres allows many NULLs, so
  // the unique key permits many finished runs but only ONE live run per lead &
  // process — the DB-level "one next step" lock.
  activeKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps WorkflowRunStep[]

  @@unique([leadId, activeKey])
  @@index([status, resumeAt])
  @@index([leadId])
  @@index([definitionId])
}

model WorkflowRunStep {
  id String @id @default(cuid())

  runId String
  run   WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  nodeId String
  kind   String

  // Idempotency guard: unique per (run, node[, occurrence]). A send node can
  // therefore fire at most once — the hard "never a duplicate message" barrier.
  dedupKey String @unique

  status String // executed | skipped | failed
  detail String @default("{}")

  createdAt DateTime @default(now())

  @@index([runId, createdAt])
}
